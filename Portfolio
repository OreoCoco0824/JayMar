.edu-degree { font-family: var(--serif); font-size: 1.4rem; font-weight: 600; color: var(--ink); }
.edu-field { font-size: 0.85rem; color: var(--muted); margin-top: 0.3rem; }
.edu-right { text-align: right; }
.edu-school { font-weight: 500; font-size: 0.9rem; color: var(--ink2); }
.edu-year { font-size: 0.8rem; color: var(--muted); margin-top: 0.3rem; }

/* ── CONTACT ── */
.contact-band {
