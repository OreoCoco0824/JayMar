  .skills-grid { grid-template-columns: 1fr 1fr; }
  .exp-item { grid-template-columns: 1fr; }
  .exp-period { text-align: left; }
  .exp-timeline::before { display: none; }
  .exp-dot { display: none; }
  .exp-body { padding-left: 0; }
  .edu-card { flex-direction: column; gap: 1rem; text-align: center; }
  .edu-right { text-align: center; }
  .contact-band { padding: 4rem 1.5rem; }
}
</style>
